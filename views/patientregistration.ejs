<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Patient Registration - MediQR</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --primary-purple: #4a00e0;
            --secondary-purple: #8e2de2;
            --text-dark: #333;
            --text-light: #888;
            --bg-white: #fff;
            --bg-light-gray: #f5f5f5;
            --success: #28a745;
            --error: #dc3545;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; }
        body { display: flex; justify-content: center; align-items: center; min-height: 100vh; background-color: #f0f2f5; position: relative; }

        .registration-page {
            display: flex; width: 100%; max-width: 1200px; min-height: 700px;
            background-color: var(--bg-white); box-shadow: 0 15px 45px rgba(0, 0, 0, 0.15);
            border-radius: 25px; overflow: hidden; z-index: 1;
        }

        /* Sidebar & Form Area (Kept your original styles) */
        .sidebar { flex: 1; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; padding: 50px; background: linear-gradient(135deg, var(--secondary-purple), var(--primary-purple)); color: var(--bg-white); }
        .sidebar h1 { font-size: 3rem; font-weight: 800; margin-bottom: 20px; }
        .sidebar p { font-size: 1.1rem; line-height: 1.6; margin-bottom: 40px; }
        .sidebar .login-btn { padding: 12px 40px; border: 2px solid var(--bg-white); border-radius: 30px; background: transparent; color: var(--bg-white); font-size: 1rem; font-weight: 600; text-decoration: none; transition: all 0.3s ease; }
        .sidebar .login-btn:hover { background-color: var(--bg-white); color: var(--primary-purple); }

        .form-area { flex: 1.2; padding: 50px; display: flex; flex-direction: column; align-items: center; }
        .tab-switcher { display: flex; width: 100%; max-width: 300px; background-color: #f0f0f0; border-radius: 30px; padding: 5px; margin-bottom: 40px; }
        .tab-switcher button { flex: 1; padding: 10px 0; border: none; border-radius: 30px; background-color: transparent; color: var(--text-dark); font-weight: 600; cursor: pointer; }
        .tab-switcher .patient-tab { background: var(--primary-purple); color: var(--bg-white); box-shadow: 0 4px 10px rgba(74, 0, 224, 0.4); }

        .form-area h2 { font-size: 1.8rem; font-weight: 700; color: var(--text-dark); margin-bottom: 30px; align-self: flex-start; }

        .input-group { position: relative; width: 100%; max-width: 400px; margin-bottom: 20px; }
        .input-group input { width: 100%; padding: 15px 15px 15px 45px; border: none; background-color: var(--bg-light-gray); border-radius: 10px; font-size: 1rem; color: var(--text-dark); outline: none; }
        .input-group i { position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: var(--text-light); font-size: 1rem; }
        
        .submit-btn { display: block; width: 100%; max-width: 400px; padding: 15px; border: none; border-radius: 50px; background: linear-gradient(90deg, var(--secondary-purple), var(--primary-purple)); color: var(--bg-white); font-size: 1.1rem; font-weight: 600; text-transform: uppercase; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 5px 15px rgba(74, 0, 224, 0.4); }
        .submit-btn:hover { opacity: 0.9; transform: translateY(-2px); }
        .submit-btn:disabled { background: #ccc; cursor: not-allowed; }

        /* OTP MODAL STYLES */
        #otp-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.7); display: none; justify-content: center;
            align-items: center; z-index: 1000; backdrop-filter: blur(5px);
        }
        .otp-box {
            background: white; padding: 40px; border-radius: 20px; text-align: center;
            max-width: 400px; width: 90%; box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }
        .otp-box h3 { margin-bottom: 10px; color: var(--primary-purple); }
        .otp-box p { font-size: 0.9rem; color: var(--text-light); margin-bottom: 20px; }
        .otp-input {
            width: 100%; padding: 15px; font-size: 1.5rem; text-align: center;
            letter-spacing: 10px; border: 2px solid var(--bg-light-gray);
            border-radius: 10px; margin-bottom: 20px; outline: none;
        }
        .otp-input:focus { border-color: var(--primary-purple); }

        .login-text { text-align: center; margin-top: 20px; font-size: 0.9rem; }
        .login-text a { color: var(--primary-purple); font-weight: 600; text-decoration: none; }
    </style>
</head>
<body>

<div id="otp-overlay">
    <div class="otp-box">
        <i class="fas fa-envelope-open-text" style="font-size: 3rem; color: var(--primary-purple); margin-bottom: 15px;"></i>
        <h3>Verify Email</h3>
        <p>We've sent a 6-digit code to your email. Please enter it below to activate your account.</p>
        <input type="text" id="otp-value" class="otp-input" placeholder="000000" maxlength="6">
        <button type="button" onclick="verifyOTP()" class="submit-btn">Verify & Register</button>
        <p id="otp-error" style="color: var(--error); font-size: 0.8rem; margin-top: 10px; display: none;"></p>
    </div>
</div>

<div class="registration-page">
    <div class="sidebar">
        <h1>Your Health in Your Hands</h1>
        <p>Securely manage and access your medical records anytime, anywhere.</p>
        <a href="/login" class="login-btn">Login</a>
    </div>

    <div class="form-area">
        <div class="tab-switcher">
            <button class="patient-tab">Patient</button>
            <a href="/hospital-register"><button>Hospital</button></a>
        </div>

        <h2>CREATE PATIENT ACCOUNT</h2>

        <form id="registration-form" style="width: 100%; max-width: 400px;">
            <div class="input-group">
                <input type="text" name="username" id="reg-username" placeholder="Username" required>
                <i class="fas fa-user"></i>
            </div>
            
            <div class="input-group">
                <input type="email" name="email" id="reg-email" placeholder="Email" required>
                <i class="fas fa-envelope"></i>
            </div>
            
            <div class="input-group">
                <input type="password" name="password" id="reg-password" placeholder="Password" required>
                <i class="fas fa-lock"></i>
            </div>

            <div class="input-group">
                <input type="number" name="adharnumber" id="reg-aadhar" placeholder="Aadhar Number" required>
                <i class="fas fa-id-card"></i>
            </div>

            <button type="submit" id="main-submit-btn" class="submit-btn">Get OTP</button>
            <p id="main-error" style="color: var(--error); font-size: 0.8rem; margin-top: 10px; text-align: center;"></p>
            
            <p class="login-text">Already have an account? <a href="/login">Login</a></p>
        </form>
    </div>
</div>

<script>
    const registrationForm = document.getElementById('registration-form');
    const otpOverlay = document.getElementById('otp-overlay');
    const mainBtn = document.getElementById('main-submit-btn');

    // Handle initial Registration (Sends OTP)
    registrationForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        mainBtn.disabled = true;
        mainBtn.innerText = "Sending OTP...";

        const formData = {
            username: document.getElementById('reg-username').value,
            email: document.getElementById('reg-email').value,
            password: document.getElementById('reg-password').value,
            adharnumber: document.getElementById('reg-aadhar').value
        };

        try {
            const response = await fetch('/user/registerpatient', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(formData)
            });

            const result = await response.json();

            if (result.success) {
                otpOverlay.style.display = 'flex';
            } else {
                document.getElementById('main-error').innerText = result.message || "Registration failed.";
                mainBtn.disabled = false;
                mainBtn.innerText = "Get OTP";
            }
        } catch (err) {
            console.error(err);
            mainBtn.disabled = false;
            mainBtn.innerText = "Get OTP";
        }
    });

    // Handle OTP Verification
    async function verifyOTP() {
        const otp = document.getElementById('otp-value').value;
        const email = document.getElementById('reg-email').value;
        const errorMsg = document.getElementById('otp-error');

        try {
            const response = await fetch('/user/verify-otp', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email, otp })
            });

            const result = await response.json();

            if (result.success) {
                alert("Account Verified Successfully!");
                window.location.href = "/login";
            } else {
                errorMsg.innerText = result.message;
                errorMsg.style.display = 'block';
            }
        } catch (err) {
            errorMsg.innerText = "Verification failed.";
            errorMsg.style.display = 'block';
        }
    }
</script>

</body>
</html>